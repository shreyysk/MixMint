# MixMint 2.0 - Django Environment Variables
# Copy this file to .env and update the values.

# --- DJANGO ---
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- DATABASE (PostgreSQL / Supabase) ---
# For Supabase, use the "Connection String" from the database settings.
# Transaction Pooler (SQLFR) via Port 6543 is recommended for Django.
# Example: postgres://postgres.yourprojectid:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://user:password@localhost:5432/mixmint

# --- APP URL ---
APP_URL=http://localhost:8000

# --- PAYMENTS (Razorpay) ---
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# --- STORAGE (Cloudflare R2) ---
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_ENDPOINT=your_r2_s3_api_endpoint
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=your_r2_public_access_url

# --- EMAIL (Resend) ---
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=noreply@yourdomain.com

# --- CRON & SECURITY ---
CRON_SECRET=your_random_string_for_cron_protection
ADMIN_EMAIL=admin@mixmint.site

# --- CELERY (Redis) ---
CELERY_BROKER_URL=redis://localhost:6379/0
